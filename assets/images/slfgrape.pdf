                      <span v-if="e.isBuyersGuid != 0" class="pl-2">
                        <a :href="'http://www.winesandvines.com/buyersguide/gotolisting.html?id=' + e.entityId + '&amp;eid=' + e.entityId">learn more</a>
                      </span>
